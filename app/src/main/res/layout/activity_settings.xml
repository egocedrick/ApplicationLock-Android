<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ App Lock Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:paddingBottom="24dp"/>

        <!-- PIN Buttons -->
        <Button
            android:id="@+id/btn_set_app_pin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set App PIN"
            android:backgroundTint="#90CAF9"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_set_lock_pin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Lock PIN"
            android:backgroundTint="#90CAF9"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"/>

        <!-- Package Input -->
        <EditText
            android:id="@+id/edit_package"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Package name (e.g. com.android.chrome)"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:backgroundTint="#90CAF9"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_add_pkg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Add"
                android:backgroundTint="#A5D6A7"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btn_remove_pkg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Remove"
                android:backgroundTint="#EF9A9A"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- Permissions -->
        <Button
            android:id="@+id/btn_usage_perm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Usage Access"
            android:backgroundTint="#FFD54F"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_overlay_perm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Overlay Permission"
            android:backgroundTint="#FFD54F"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"/>

        <!-- Admin -->
        <Button
            android:id="@+id/btn_enable_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Device Admin"
            android:backgroundTint="#81D4FA"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_disable_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disable Device Admin"
            android:backgroundTint="#EF9A9A"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"/>

        <!-- Protection -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start"
                android:backgroundTint="#A5D6A7"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Stop"
                android:backgroundTint="#EF9A9A"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/txt_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textColor="#333333"
            android:textSize="14sp"/>
    </LinearLayout>
</ScrollView>